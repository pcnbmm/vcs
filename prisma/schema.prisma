  cre_by           String?   @db.VarChar(8)
  cre_date         DateTime? @db.Date
  upd_by           String?   @db.VarChar(8)
  upd_date         DateTime? @db.Date
}

model Booking {
  id             String        @id
  requesterId    String
  department     String
  objective      String
  origin         String
  destination    String
  requestDate    DateTime      @default(now())
  startDateTime  DateTime
  endDateTime    DateTime
  passengerCount Int
  status         BookingStatus @default(PENDING)
  rejectReason   String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime
  bookingNo      String?       @unique
  User           User          @relation(fields: [requesterId], references: [id])
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  IN_USE
  COMPLETED
}

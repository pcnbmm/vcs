generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  createdAt DateTime  @default(now())
  password  String
  role      String    @default("USER")
  username  String    @unique
  Booking   Booking[]
  sessions  Session[]
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Booking {
  id             String        @id
  requesterId    String
  department     String
  objective      String
  origin         String
  destination    String
  requestDate    DateTime      @default(now())
  startDateTime  DateTime
  endDateTime    DateTime
  passengerCount Int
  status         BookingStatus @default(PENDING)
  rejectReason   String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime
  bookingNo      String?       @unique
  User           User          @relation(fields: [requesterId], references: [id])
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model vc_car_master {
  car_id               Int                   @id @default(autoincrement())
  car_number           String?               @db.VarChar(50)
  car_province_id      Int?
  car_type_id          Int?
  car_spec_id          Int?
  car_brand_id         Int?
  car_type_regis_id    Int?
  color_id             Int?
  oil_type_id          Int?
  own_div_code         Int?
  fiscal_year          Int?
  start_date           String?               @db.VarChar(50)
  end_date             String?               @db.VarChar(50)
  regis_date           String?               @db.VarChar(50)
  car_status_id        Int?
  machine_no           String?               @db.VarChar(50)
  body_no              String?               @db.VarChar(50)
  cylinder_capacityp   String?               @db.VarChar(50)
  oil_expense          Float?                @db.Real
  refund_vat           Int?
  flag                 String?               @db.VarChar(50)
  cre_by               Int?
  cre_date             String?               @db.VarChar(50)
  upd_by               Int?
  upd_date             String?               @db.VarChar(50)
  ref_car              String?               @db.VarChar(50)
  horse_power          String?               @db.VarChar(50)
  weight               String?               @db.VarChar(50)
  machine_id           String?               @db.VarChar(50)
  purchase_id          Int?
  fleetcard_no         BigInt?
  vc_car_brand         vc_car_brand?         @relation(fields: [car_brand_id], references: [car_brand_id])
  vc_register_province vc_register_province? @relation(fields: [car_province_id], references: [regis_province_id])
  vc_car_spec          vc_car_spec?          @relation(fields: [car_spec_id], references: [car_spec_id])
  vc_car_status        vc_car_status?        @relation(fields: [car_status_id], references: [car_status_id])
  vc_car_type          vc_car_type?          @relation(fields: [car_type_id], references: [car_type_id])
  vc_type_regis        vc_type_regis?        @relation(fields: [car_type_regis_id], references: [type_regis_id])
  vc_color             vc_color?             @relation(fields: [color_id], references: [color_id])
  vc_oil_type          vc_oil_type?          @relation(fields: [oil_type_id], references: [oil_type_id])
}

model VcOrderItems {
  request_id       Int       @id @default(autoincrement())
  use_div_code     String?   @db.VarChar(100)
  userid           String?   @db.Char(8)
  user_mobile      String?   @db.VarChar(20)
  journey_date     DateTime? @db.Date
  return_date      DateTime? @db.Date
  start_place      String?   @db.VarChar(200)
  journey_place    String?   @db.VarChar(500)
  journey_province String?   @db.VarChar(100)
  journey_causes   String?
  journer_time     String?   @db.VarChar(10)
  return_time      String?   @db.VarChar(10)
  car_spec_id      String?   @db.VarChar(100)
  passenger_amount Int?
  approve_id       String?   @db.Char(8)
  status_use_id    Int?
  self_drive       Boolean?
  journey_lat      Float?
  journey_long     Float?
  cre_by           String?   @db.VarChar(20)
  cre_date         DateTime?
  upd_by           String?   @db.VarChar(20)
  upd_date         DateTime?

  @@map("vc_order_item")
}

model fleetcard_transactions {
  fleetcard_trans_id Int       @id @default(autoincrement())
  fleetcard_id       String?   @db.VarChar(50)
  invoiceNo          String?   @db.VarChar(50)
  transactionDate    DateTime? @db.Date
  transactionTime    DateTime? @db.Time(6)
  bilingDate         String?   @db.VarChar(50)
  merchantID         String?   @db.VarChar(50)
  taxID              String?   @db.VarChar(50)
  branchCode         String?   @db.VarChar(50)
  stationName        String?   @db.VarChar(100)
  stationAddress     String?   @db.VarChar(200)
  fuelTypeCode       String?   @db.VarChar(50)
  fuelTypeName       String?   @db.VarChar(50)
  vatRefund          String?   @db.VarChar(50)
  amountBeforeVat    Decimal?  @db.Decimal(15, 2)
  volumeLiter        Decimal?  @db.Decimal(15, 3)
  transactionStatus  String?   @db.Char(1)
  sapPostingStatus   String?   @db.Char(1)
  jvID               String?   @db.VarChar(50)
}

model vc_car_brand {
  car_brand_id    Int             @id @default(autoincrement())
  car_brand_name  String?         @db.VarChar(255)
  car_series_name String?         @db.VarChar(255)
  flag_del        String?         @db.VarChar(255)
  cre_by          Int?
  cre_date        String?         @db.VarChar(255)
  upd_by          Int?
  upd_date        String?         @db.VarChar(255)
  vc_car_master   vc_car_master[]
}

model vc_car_spec {
  car_spec_id   Int             @id @default(autoincrement())
  car_spec_name String?         @db.VarChar(256)
  flag_del      String?         @db.VarChar(50)
  cre_by        Int?
  cre_date      String?         @db.VarChar(50)
  upd_by        Int?
  upd_date      String?         @db.VarChar(50)
  vc_car_master vc_car_master[]
}

model vc_car_status {
  car_status_id   Int             @id @default(autoincrement())
  car_status_name String?         @db.VarChar(50)
  flag_del        String?         @db.Char(1)
  cre_by          String?         @db.VarChar(20)
  cre_date        DateTime?       @db.Date
  upd_by          String?         @db.VarChar(20)
  upd_date        DateTime?       @db.Date
  vc_car_master   vc_car_master[]
}

model vc_car_type {
  car_type_id   Int             @id @default(autoincrement())
  car_type_name String?         @db.VarChar(50)
  flag_del      String?         @db.VarChar(50)
  cre_by        Int?
  cre_date      String?         @db.VarChar(50)
  upd_by        Int?
  upd_date      String?         @db.VarChar(50)
  vc_car_master vc_car_master[]
}

model vc_color {
  color_id      Int             @id @default(autoincrement())
  color_name    String?         @db.VarChar(50)
  flag_del      String?         @db.VarChar(50)
  cre_by        Int?
  cre_date      String?         @db.VarChar(50)
  upd_by        Int?
  upd_date      String?         @db.VarChar(50)
  vc_car_master vc_car_master[]
}

model vc_company {
  company_id   Int       @id @default(autoincrement())
  company_name String?   @db.VarChar(200)
  company_tel  String?   @db.VarChar(50)
  flag_del     String?   @db.Char(1)
  cre_by       String?   @db.VarChar(50)
  cre_date     DateTime? @db.Date
  upd_by       String?   @db.VarChar(50)
  upd_date     DateTime? @db.Date
}

model vc_contract_details {
  contract_id           Int       @id @default(autoincrement())
  rent_no               String?   @db.VarChar(100)
  arbitrator_chair      Int?
  arbitrator_chair_name String?   @db.VarChar(255)
  arbitrator1           Int?
  arbitrator1_name      String?   @db.VarChar(255)
  arbitrator2           Int?
  arbitrator2_name      String?   @db.VarChar(255)
  arbitrator3           Int?
  arbitrator3_name      String?   @db.VarChar(255)
  start_date            DateTime? @db.Date
  end_date              DateTime? @db.Date
  arbitrator4           Int?
  arbitrator4_name      String?   @db.VarChar(255)
}

model vc_fuel_item {
  fuel_item_id    Int       @id @default(autoincrement())
  car_id          Int?
  oil_type_id     Int?
  fuel_date       DateTime? @db.Date
  fuel_time       DateTime? @db.Time(6)
  driver_id       Int?
  fuel_station_id Int?
  mile_car        Int?
  pay_method      String?   @db.Char(1)
  pay_card_id     String?   @db.VarChar(50)
  amount_liter    Decimal?  @db.Decimal(12, 2)
  amount_baht     Decimal?  @db.Decimal(12, 2)
  liter_price     Decimal?  @db.Decimal(12, 2)
  amount_vat      Decimal?  @db.Decimal(12, 2)
  invoice_no      String?   @db.VarChar(50)
  cre_by          String?   @db.VarChar(50)
  cre_date        DateTime? @db.Date
  upd_by          String?   @db.VarChar(8)
  upd_date        DateTime? @db.Date
}

model vc_function {
  function_id Int       @id @default(autoincrement())
  menu_id     Int?
  func_name   String?   @db.VarChar(100)
  func_code   String?   @db.VarChar(50)
  cre_by      String?   @db.VarChar(8)
  cre_date    DateTime? @db.Date
  upd_by      String?   @db.VarChar(8)
  upd_date    DateTime? @db.Date
}

model vc_menu {
  menu_id    Int       @id @default(autoincrement())
  menuname   String?   @db.VarChar(100)
  route_path String?   @db.VarChar(100)
  menu_icon  String?   @db.VarChar(50)
  sort_order Int?
  cre_by     String?   @db.VarChar(8)
  cre_date   DateTime? @db.Date
  upd_by     String?   @db.VarChar(8)
  upd_date   DateTime? @db.Date
}

model vc_nt_car {
  nt_car_id                  Int       @id @default(autoincrement())
  car_id                     Int?
  asset_no                   String?   @db.VarChar(13)
  car_account_no_tax         String?   @db.VarChar(50)
  car_account_no_insure      String?   @db.VarChar(50)
  car_cost_center            String?   @db.VarChar(50)
  car_business_process       String?   @db.VarChar(50)
  car_functional_area        String?   @db.VarChar(50)
  car_segment_code           String?   @db.VarChar(50)
  car_product_code           String?   @db.VarChar(50)
  purchase_price             Decimal?  @db.Decimal(12, 2)
  insure_cartype             Int?
  insure_third_party_cartype Int?
  cre_by                     String?   @db.VarChar(50)
  cre_date                   DateTime? @db.Date
  upd_by                     String?   @db.VarChar(50)
  upd_date                   DateTime? @db.Date
}

model vc_oil_type {
  oil_type_id    Int             @id @default(autoincrement())
  oil_type_name  String?         @db.VarChar(200)
  oil_type_group Int?
  flag_del       String?         @db.Char(1)
  cre_by         String?         @db.VarChar(8)
  cre_date       DateTime?       @db.Date
  upd_by         String?         @db.VarChar(8)
  upd_date       DateTime?       @db.Date
  vc_car_master  vc_car_master[]
}

model vc_permission {
  role_id     Int       @id @default(autoincrement())
  function_id Int?
  can_access  Boolean?
  cre_by      String?   @db.VarChar(8)
  cre_date    DateTime? @db.Date
  upd_by      String?   @db.VarChar(8)
  upd_date    DateTime? @db.Date
}

model vc_register_province {
  regis_province_id   Int             @id @default(autoincrement())
  regis_province_name String?         @db.VarChar(50)
  short_name          String?         @db.VarChar(50)
  region_id           Int?
  flag_del            String?         @db.VarChar(50)
  cre_by              Int?
  cre_date            String?         @db.VarChar(50)
  upd_by              Int?
  upd_date            String?         @db.VarChar(50)
  vc_car_master       vc_car_master[]
}

model vc_replacement {
  replacement_id     Int       @id @default(autoincrement())
  car_id             Int?
  replacemant_car_id Int?
  start_date         DateTime? @db.Date
  end_date           DateTime? @db.Date
  cre_by             String?   @db.VarChar(50)
  cre_date           DateTime? @db.Date
  upd_by             String?   @db.VarChar(50)
  upd_date           DateTime? @db.Date
}

model vc_roles {
  roles_id    Int       @id @default(autoincrement())
  roles_name  String?   @db.VarChar(50)
  description String?   @db.VarChar(255)
  cre_by      String?   @db.VarChar(8)
  cre_date    DateTime? @db.Date
  upd_by      String?   @db.VarChar(8)
  upd_date    DateTime? @db.Date
}

model vc_type_regis {
  type_regis_id   Int             @id @default(autoincrement())
  type_regis_name String?         @db.VarChar(100)
  flag_del        String?         @db.Char(1)
  cre_by          String?         @db.VarChar(50)
  cre_date        DateTime?       @db.Date
  upd_by          String?         @db.VarChar(50)
  upd_date        DateTime?       @db.Date
  vc_car_master   vc_car_master[]
}

model vc_user_roles {
  user_id  Int       @id @default(autoincrement())
  roles_id Int?
  cre_by   String?   @db.VarChar(50)
  cre_date DateTime? @db.Date
  upd_by   String?   @db.VarChar(50)
  upd_date DateTime? @db.Date
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  IN_USE
  COMPLETED
}

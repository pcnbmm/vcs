generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(cuid())
  username  String    @unique // ใช้รหัสพนักงานสำหรับ Login
  email     String    @unique // เก็บ Email ไว้เหมือนเดิม
  name      String?
  password  String // เก็บ Hash รหัสผ่าน
  role      String    @default("USER")
  sessions  Session[]
  createdAt DateTime  @default(now())
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
